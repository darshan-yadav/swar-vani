# Swar-Vani Web — Environment Variables
# Copy this to .env and fill in your values

# API Gateway endpoint (from CDK output: SwarVaniApiStack.ApiUrl)
VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/dev

# Lambda Function URL for voice (from CDK output: SwarVaniApiStack.VoiceFunctionUrl)
VITE_VOICE_URL=https://xxxxxxxxxx.lambda-url.us-east-1.on.aws

# Cognito User Pool (from CDK output: SwarVaniAuthStack.UserPoolId)
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX

# Cognito App Client (from CDK output: SwarVaniAuthStack.UserPoolClientId)
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
